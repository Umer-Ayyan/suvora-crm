generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── LEAD ──────────────────────────────────────────────────────────────────
model Lead {
  id           String    @id @default(cuid())
  name         String
  company      String?
  email        String?
  phone        String?
  country      String?
  industry     String?
  source       String
  status       String    @default("new")
  budget       String?
  dealValue    Float?
  notes        String?
  followUpDate DateTime?
  priority     String?   @default("medium")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt @default(now())

  createdById String?
  createdBy   User?   @relation(fields: [createdById], references: [id])

  clientId    String?
  client      Client? @relation(fields: [clientId], references: [id])

  activities  LeadActivity[]
  leadNotes   LeadNote[]
  tasks       Task[]

  @@index([status])
  @@index([createdById])
  @@index([followUpDate])
  @@index([clientId])
}

// ─── LEAD ACTIVITY (timeline) ──────────────────────────────────────────────
model LeadActivity {
  id        String   @id @default(cuid())
  note      String
  createdAt DateTime @default(now())

  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  userId String?
  user   User?   @relation(fields: [userId], references: [id])
}

// ─── LEAD NOTES ────────────────────────────────────────────────────────────
model LeadNote {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())

  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  userId String?
  user   User?   @relation("LeadNoteAuthor", fields: [userId], references: [id])
}

// ─── ACTIVITY LOG (audit trail) ─────────────────────────────────────────────
model ActivityLog {
  id          String   @id @default(cuid())
  action      String
  description String
  createdAt   DateTime @default(now())

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  @@index([action])
  @@index([createdAt])
}

// ─── CLIENT ────────────────────────────────────────────────────────────────
model Client {
  id       String  @id @default(cuid())
  name     String
  company  String
  email    String?
  phone    String?
  country  String?
  industry String?
  website  String?
  notes    String?
  status   String  @default("active") // active | inactive

  totalRevenue Float    @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt @default(now())

  createdById String?
  createdBy   User?   @relation("ClientCreator", fields: [createdById], references: [id])

  leads      Lead[]
  tasks      Task[]
  quotations Quotation[]
  invoices   Invoice[]
}

// ─── TASK ──────────────────────────────────────────────────────────────────
model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  status      String    @default("pending")  // pending | in_progress | completed | cancelled
  priority    String    @default("medium")   // low | medium | high | urgent
  dueDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt @default(now())

  assignedToId String?
  assignedTo   User?   @relation("TaskAssignee", fields: [assignedToId], references: [id])

  createdById String?
  createdBy   User?   @relation("TaskCreator", fields: [createdById], references: [id])

  leadId String?
  lead   Lead?   @relation(fields: [leadId], references: [id], onDelete: SetNull)

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([assignedToId])
  @@index([dueDate])
}

// ─── NOTIFICATION ──────────────────────────────────────────────────────────
model Notification {
  id        String   @id @default(cuid())
  title     String
  message   String
  type      String   @default("info") // info | success | warning | error
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── ATTENDANCE ────────────────────────────────────────────────────────────
model Attendance {
  id           String    @id @default(cuid())
  date         DateTime  @db.Date
  checkInTime  DateTime?
  status       String    @default("absent")
  deductionPct Float     @default(0)
  notes        String?
  createdAt    DateTime  @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([date])
  @@index([status])
}

// ─── PAYSLIP ───────────────────────────────────────────────────────────────
model Payslip {
  id             String   @id @default(cuid())
  month          Int
  year           Int
  baseSalary     Float
  workingDays    Int
  presentDays    Int
  lateDays       Int
  halfDays       Int
  absentDays     Int
  totalDeduction Float
  netSalary      Float
  generatedAt    DateTime @default(now())

  userId        String
  user          User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  generatedById String?
  generatedBy   User?  @relation("PayslipGenerator", fields: [generatedById], references: [id])

  @@unique([userId, month, year])
  @@index([year, month])
}

// ─── LEAVE REQUEST ─────────────────────────────────────────────────────────
model LeaveRequest {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String   // annual | sick | casual | unpaid | other
  startDate   DateTime @db.Date
  endDate     DateTime @db.Date
  days        Int
  reason      String?
  status      String   @default("pending") // pending | approved | rejected
  reviewedById String?
  reviewedBy   User?   @relation("LeaveReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewNote  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt @default(now())

  @@index([userId])
  @@index([status])
  @@index([startDate])
}

// ─── CHAT ──────────────────────────────────────────────────────────────────
model ChatRoom {
  id          String   @id @default(cuid())
  name        String?                        // null for direct messages
  type        String   @default("direct")   // direct | group
  createdAt   DateTime @default(now())
  createdById String?

  members     ChatRoomMember[]
  messages    ChatMessage[]
}

model ChatRoomMember {
  id       String   @id @default(cuid())
  roomId   String
  room     ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  isHidden Boolean  @default(false)  // true = admin spy, not shown to others
  joinedAt DateTime @default(now())

  @@unique([roomId, userId])
  @@index([userId])
  @@index([roomId])
}

model ChatMessage {
  id        String   @id @default(cuid())
  content   String
  roomId    String
  room      ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  senderId  String
  sender    User     @relation("ChatSender", fields: [senderId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  editedAt  DateTime?
  isDeleted Boolean  @default(false)
  readBy    ChatMessageRead[]
  hiddenBy  ChatMessageHide[]

  @@index([roomId, createdAt])
  @@index([senderId])
}

model ChatMessageHide {
  id        String      @id @default(cuid())
  messageId String
  message   ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  hiddenAt  DateTime    @default(now())

  @@unique([messageId, userId])
  @@index([userId])
}

model ChatMessageRead {
  id        String      @id @default(cuid())
  messageId String
  message   ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  readAt    DateTime    @default(now())

  @@unique([messageId, userId])
  @@index([messageId])
  @@index([userId])
}

// ─── CUSTOM ROLE ───────────────────────────────────────────────────────────
model CustomRole {
  id          String   @id @default(cuid())
  name        String   @unique
  color       String   @default("#7c3aed")
  // permissions JSON: { leads, clients, invoices, quotations, tasks, employees, attendance, goals, reports }
  permissions Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt @default(now())
  users       User[]
}

// ─── USER ──────────────────────────────────────────────────────────────────
model User {
  id           String    @id @default(cuid())
  name         String
  employeeId   String    @unique
  password     String
  role         String    @default("employee") // admin | manager | employee
  customRoleId String?
  customRole   CustomRole? @relation(fields: [customRoleId], references: [id], onDelete: SetNull)
  salary       Float     @default(0)
  department   String?
  phone        String?
  // Extended HR profile fields
  email        String?
  designation  String?
  joiningDate  DateTime?
  cnic         String?
  address      String?
  city         String?
  emergencyContactName  String?
  emergencyContactPhone String?
  bankName     String?
  bankAccount  String?
  bloodGroup   String?
  gender       String?
  status         String    @default("active") // active | inactive | terminated
  lastSeenAt     DateTime?
  sessionVersion Int       @default(0)
  createdAt      DateTime  @default(now())

  leads             Lead[]
  activityLogs      ActivityLog[]
  leadActivities    LeadActivity[]
  leadNotes         LeadNote[]    @relation("LeadNoteAuthor")
  attendances       Attendance[]
  payslips          Payslip[]
  generatedPayslips Payslip[]     @relation("PayslipGenerator")
  clientsCreated    Client[]      @relation("ClientCreator")
  tasksAssigned     Task[]        @relation("TaskAssignee")
  tasksCreated      Task[]        @relation("TaskCreator")
  notifications     Notification[]
  quotations        Quotation[]
  invoices          Invoice[]
  goals             Goal[]
  goalsCreated      Goal[]        @relation("GoalCreator")
  documents         EmployeeDocument[]
  chatRooms         ChatRoomMember[]
  chatMessages      ChatMessage[] @relation("ChatSender")
  messageReads      ChatMessageRead[]
  messageHides      ChatMessageHide[]
  leaveRequests     LeaveRequest[]
  leaveReviews      LeaveRequest[] @relation("LeaveReviewer")
}

// ─── EMPLOYEE DOCUMENT ─────────────────────────────────────────────────────
model EmployeeDocument {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String                        // display name
  category    String   @default("other")   // offer_letter | nda | contract | id_copy | other
  fileName    String                        // original file name
  fileType    String                        // mime type
  fileSize    Int                           // bytes
  fileData    String                        // base64 encoded file
  notes       String?
  uploadedAt  DateTime @default(now())

  @@index([userId])
  @@index([category])
}

// ─── QUOTATION ─────────────────────────────────────────────────────────────
model Quotation {
  id           String   @id @default(cuid())
  number       String   @unique // e.g. QT-0001
  status       String   @default("draft") // draft | sent | accepted | rejected | expired

  // Client info (can be linked or manual)
  clientId     String?
  client       Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  clientName   String   // stored at creation time
  clientEmail  String?
  clientCompany String?

  // Validity
  issueDate    DateTime @default(now())
  validUntil   DateTime?

  // Financials
  subtotal     Float    @default(0)
  discountPct  Float    @default(0)  // percentage 0–100
  taxPct       Float    @default(0)  // percentage 0–100
  total        Float    @default(0)

  notes        String?
  terms        String?

  items        QuotationItem[]

  createdById  String?
  createdBy    User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt @default(now())

  @@index([status])
  @@index([createdAt])
}

model QuotationItem {
  id          String    @id @default(cuid())
  quotationId String
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  description String
  quantity    Float     @default(1)
  unitPrice   Float     @default(0)
  amount      Float     @default(0)
  order       Int       @default(0)
}

// ─── INVOICE ───────────────────────────────────────────────────────────────
model Invoice {
  id           String   @id @default(cuid())
  number       String   @unique // e.g. INV-0001
  status       String   @default("unpaid") // unpaid | paid | overdue | partial

  // Client info
  clientId      String?
  client        Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  clientName    String
  clientEmail   String?
  clientCompany String?

  // Linked quotation (optional)
  quotationId   String?
  quotationNumber String?

  // Dates
  issueDate     DateTime @default(now())
  dueDate       DateTime?
  paidAt        DateTime?

  // Financials
  subtotal      Float    @default(0)
  discountPct   Float    @default(0)
  taxPct        Float    @default(0)
  total         Float    @default(0)
  amountPaid    Float    @default(0)

  notes         String?
  terms         String?

  items         InvoiceItem[]

  createdById   String?
  createdBy     User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt @default(now())

  @@index([status])
  @@index([dueDate])
  @@index([createdAt])
}

model InvoiceItem {
  id          String  @id @default(cuid())
  invoiceId   String
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String
  quantity    Float   @default(1)
  unitPrice   Float   @default(0)
  amount      Float   @default(0)
  order       Int     @default(0)
}

// ─── GOAL ──────────────────────────────────────────────────────────────────
model Goal {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  type        String   @default("leads")   // leads | revenue | tasks | custom
  targetValue Float    @default(0)
  currentValue Float   @default(0)
  period      String   @default("monthly") // monthly | quarterly | yearly
  month       Int?     // 1-12
  year        Int
  notes       String?
  createdById String?
  createdBy   User?    @relation("GoalCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt @default(now())

  @@index([userId])
  @@index([year, month])
}
